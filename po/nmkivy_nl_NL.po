msgid ""
"Failed to start network and/or wifi radio\n"
"Make sure the wifi is enabled."
msgstr ""
"Niet gelukt om het netwerk en/of de wifi radio te starten\n"
"Vergewis u ervan dat de wifi beschikbaar is."

#: ../main.py:157
msgid "No"
msgstr "Nee"

