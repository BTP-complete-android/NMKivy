#: ../main.py:334
msgid ""
"Cannot connect to the BTP+ server. Please use another connection or contact "
"your IT department."
msgstr ""
"Kan geen verbinding maken met de BTP+ server. Gebruik een andere verbinding "
"aub of neem contact op met uw IT afdeling."

#: ../main.py:115
msgid "Connect"
msgstr "Verbind"

